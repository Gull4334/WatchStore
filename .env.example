# =============================================
# WatchStore PK — Environment Variables
# Copy this file to .env and fill in values
# NEVER commit .env to git
# =============================================

# Server
NODE_ENV=development
PORT=5000

# Database (Supabase Session Pooler)
DB_HOST=aws-1-eu-west-3.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres.uoehlrvdyhsdcstgadim
DB_PASSWORD=!WatchStore!
DB_SSL=true

# JWT
JWT_SECRET=change_this_to_a_long_random_secret_min_64_chars
JWT_EXPIRES_IN=24h

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Supabase Storage (for image uploads)
SUPABASE_URL=https://uoehlrvdyhsdcstgadim.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_KEY=your_supabase_service_key_here

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Email (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
ADMIN_EMAIL=admin@watchstorepk.com

# Store Info
STORE_NAME=WatchStore PK
STORE_WHATSAPP=+923001234567
